PROJECT_NAME           = Marrow
PROJECT_BRIEF          = Runtime, renderer, editor, and format reference documentation
OUTPUT_DIRECTORY       = @PROJECT_BINARY_DIR@/docs
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OPTIMIZE_OUTPUT_FOR_C  = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
QUIET                  = NO
WARNINGS               = YES
WARN_IF_DOC_ERROR      = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = YES
JAVADOC_AUTOBRIEF      = YES
SORT_MEMBER_DOCS       = NO
SORT_BRIEF_DOCS        = NO
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
TOC_INCLUDE_HEADINGS   = 3
FILE_PATTERNS          = *.h \
                         *.hpp \
                         *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = @PROJECT_SOURCE_DIR@/docs/quick-start.md
INPUT                  = @PROJECT_SOURCE_DIR@/include \
                         @PROJECT_SOURCE_DIR@/docs/quick-start.md \
                         @PROJECT_SOURCE_DIR@/docs/concepts.md \
                         @PROJECT_SOURCE_DIR@/docs/format-spec.md \
                         @PROJECT_SOURCE_DIR@/docs/fixtures.md
EXCLUDE_SYMBOLS        = detail
